generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS & CONFIGURATION DEFINITIONS
// ==========================================

enum RequestStatus {
  pending
  approved
  declined
}

enum InterviewStatus {
  scheduled
  in_progress
  completed
  cancelled
  reschedule_requested
  confirmed
}

enum InterviewFormat {
  video
  coding_test
  mixed
}

enum JobPostingStatus {
  active
  closed
  paused
}

enum ApplicationStatus {
  applied
  reviewed
  shortlisted
  interview
  offer
  hired
  rejected
}

enum Verdict {
  shortlist
  reject
  on_hold
  next_round
}

enum OfferStatus {
  sent
  accepted
  declined
  negotiation
}

enum AvailabilityStatus {
  available
  not_available
  spot_available
}

// ==========================================
// 1. AUTHENTICATION & CORE USER ENTITIES
// ==========================================

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  mobileNumber String   @unique
  password     String?
  roles        Int      @default(1)   // default Job Seeker
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  otps             Otp[]
  jobSeekerProfile JobSeekerProfile?
  teamMemberships  TeamMember[]
  feedbacksGiven   InterviewFeedback[]
}

model Otp {
  id           String   @id @default(uuid())
  mobileNumber String
  otpHash      String
  expiresAt    DateTime
  purpose      String   // e.g., "authentication" | "company_registration"
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mobileNumber])
}

// ==========================================
// 2. JOB SEEKER PROFILE & RESUME DATA
// ==========================================

model JobSeekerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  email              String             @unique
  profilePhotoUrl    String?
  location           String?
  phone              String?
  linkedin           String?
  github             String?
  portfolio          String?
  bio                String?
  availabilityStatus AvailabilityStatus @default(available)
  jobPreferences     Json?              // e.g., { roles: [], industries: [], expectedSalary: "" }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Profile Sub-sections
  resumes        Resume[]
  skills         Skill[]
  education      Education[]
  experience     Experience[]
  projects       Project[]
  certifications Certification[]
  languages      Language[]
  achievements   Achievement[]
  applications   Application[]
}

model Resume {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  name               String
  source             String           // "built" | "uploaded"
  filePath           String?          // Relative VPS disk target path
  isPrimary          Boolean          @default(false)

  // ATS Analysis & Structural Data Extraction
  atsScore      Int?
  content       Json?                 // Sections layout: { contactInfo, skills[], experience[] }
  aiSuggestions Json?                 // Gap optimization rules: { missingSections: [], keywordGaps: [] }

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
}

model Skill {
  id                 String           @id @default(uuid())
  name               String
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())
}

model Education {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  institution        String
  degree             String
  field              String
  location           String?
  startMonth         String?
  startYear          String?
  endMonth           String?
  endYear            String?
  cgpa               String?
  description        String?          @db.Text
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Experience {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  company            String
  role               String
  location           String?
  startMonth         String?
  startYear          String?
  endMonth           String?
  endYear            String?
  current            Boolean          @default(false)
  description        String?          @db.Text
  skillsUsed         String[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Project {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  name               String
  description        String           @db.Text
  technologies       String[]
  githubLink         String?
  liveLink           String?
  startDate          String?
  endDate            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Certification {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  name               String
  organization       String
  issueDate          String?
  credentialUrl      String?
  createdAt          DateTime         @default(now())
}

model Language {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  language           String
  proficiency        String
  createdAt          DateTime         @default(now())
}

model Achievement {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  title              String
  description        String?          @db.Text
  year               String?
  createdAt          DateTime         @default(now())
}

// ==========================================
// 3. COMPANY & PIPELINE MANAGEMENT
// ==========================================

model Company {
  id                 String   @id @default(uuid())
  name               String   @unique
  industry           String
  size               String
  logoUrl            String?  @db.Text
  registrationNumber String?
  isVerified         Boolean  @default(false)
  verificationBadge  String   @default("none") // "none" | "pending" | "verified"
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  teamMembers      TeamMember[]
  jobPostings      JobPosting[]
  interviewBatches InterviewBatch[]
}

model TeamMember {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String   // e.g., "admin" | "hr_manager" | "interviewer" | "viewer" (company-specific)
  status    String   @default("active") // "invited" | "active" | "deactivated"
  createdAt DateTime @default(now())
}

model JobPosting {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title              String
  department         String?
  description        String           @db.Text
  jobType            String           // "Full-time" | "Part-time" | "Contract" | "Freelance" | "Spot"
  locationType       String?          // "On-site" | "Remote" | "Hybrid"
  location           String?          // City name
  experienceRequired String?          // e.g., "2-5 years"
  requiredSkills     Json             // Array of skills
  salaryRange        String?
  deadline           DateTime?
  openings           Int              @default(1)
  status             JobPostingStatus @default(active)
  metadata           Json?            // Additional flexible data
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  applications     Application[]
  interviewBatches InterviewBatch[]

  @@index([companyId])
  @@index([status])
}

model Application {
  id                 String            @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile  @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  jobPostingId       String
  jobPosting         JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  resumeId           String
  resume             Resume            @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  status             ApplicationStatus @default(applied)
  appliedAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  interviews   Interview[]
  offerLetters OfferLetter[]
}

// ==========================================
// 4. INTERVIEWS, FEEDBACK, & OFFERS
// ==========================================

model InterviewBatch {
  id                   String   @id @default(uuid())
  companyId            String
  company              Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobPostingId         String?
  jobPosting           JobPosting? @relation(fields: [jobPostingId], references: [id])
  startTime            DateTime
  slotDuration         Int          // minutes
  interviewFormat      InterviewFormat
  interviewerIds       String[]
  selectedCandidateIds String[]     // application IDs
  status               String       @default("scheduled")
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  interviews Interview[]
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  batchId         String?
  batch           InterviewBatch? @relation(fields: [batchId], references: [id])
  scheduledTime   DateTime
  durationMinutes Int             @default(15)
  format          InterviewFormat @default(video)
  interviewerIds  String[]
  livekitRoomName String          @unique
  joinLink        String
  status          InterviewStatus @default(scheduled)
  recordingPath   String?
  createdAt       DateTime        @default(now())
  feedbacks       InterviewFeedback[]
  rescheduleRequests RescheduleRequest[]
}

model RescheduleRequest {
  id            String         @id @default(uuid())
  interviewId   String
  interview     Interview      @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  requestedBy   String         @default("job_seeker") // "job_seeker" or "company"
  proposedTime  DateTime
  candidateNote String?        @db.Text
  status        RequestStatus  @default(pending)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model InterviewFeedback {
  id                    String    @id @default(uuid())
  interviewId           String
  interview             Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewerId         String
  interviewer           User      @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  technicalRating       Int       // 1-5 scalar evaluation
  communicationRating   Int       // 1-5 scalar evaluation
  problemSolvingRating  Int       // 1-5 scalar evaluation
  verdict               Verdict
  notes                 String?   @db.Text
  createdAt             DateTime  @default(now())
}

model OfferLetter {
  id            String      @id @default(uuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  content       Json        // Flexible custom payload model structural tracking
  filePath      String      // System relative layout tracking parameters
  status        OfferStatus @default(sent)
  sentAt        DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}