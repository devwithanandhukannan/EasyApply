generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── PIPELINE ENUMS ──────────────────────────────────────────────────

enum RequestStatus {
  pending
  approved
  declined
}

enum OfferLetterStatus {
  draft
  pending
  sent
  viewed
  accepted
  declined
  negotiating
  expired
  withdrawn
}


enum ApplicationStatus {
  applied           // Applied
  screened          // Screened
  technical_round   // Technical Round
  hr_round          // HR Round
  offer_sent        // Offer Sent
  hired             // Hired
  rejected          // Rejected (Accessible dynamically from any stage)
}

enum InterviewStatus {
  scheduled
  in_progress
  completed
  cancelled
  reschedule_requested
  confirmed
}

enum InterviewFormat {
  video
  coding_test
  mixed
}

enum JobPostingStatus {
  active
  closed
  paused
}

enum Verdict {
  shortlist
  reject
  on_hold
  next_round
}

enum OfferStatus {
  sent
  accepted
  declined
  negotiation
}

enum AvailabilityStatus {
  available
  not_available
  spot_available
}

// ─── CORE SYSTEM MODELS ──────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  mobileNumber String   @unique
  globalRoles  Int      @default(1)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  otps             Otp[]
  jobSeekerProfile JobSeekerProfile?
  teamMemberships  TeamMember[]
  feedbacksGiven   InterviewFeedback[]

  @@index([mobileNumber])
}

model Otp {
  id           String   @id @default(uuid())
  mobileNumber String
  otpHash      String
  expiresAt    DateTime
  purpose      String
  createdAt    DateTime @default(now())
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([mobileNumber])
  @@index([expiresAt])
}

model JobSeekerProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName           String
  email              String             @unique
  profilePhotoUrl    String?
  location           String?
  phone              String?
  linkedin           String?
  github             String?
  portfolio          String?
  bio                String?
  availabilityStatus AvailabilityStatus @default(available)
  jobPreferences     Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  resumes        Resume[]
  skills         Skill[]
  education      Education[]
  experience     Experience[]
  projects       Project[]
  certifications Certification[]
  languages      Language[]
  achievements   Achievement[]
  applications   Application[]

  @@index([email])
  @@index([userId])
}

model Resume {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  name               String
  source             String
  filePath           String?
  isPrimary          Boolean          @default(false)
  atsScore           Int?
  content            Json?
  aiSuggestions      Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  applications       Application[]

  @@index([jobSeekerProfileId])
}

model Skill {
  id                 String           @id @default(uuid())
  name               String
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  createdAt          DateTime         @default(now())

  @@index([jobSeekerProfileId])
}

model Education {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  institution        String
  degree             String
  field              String
  location           String?
  startMonth         String?
  startYear          String?
  endMonth           String?
  endYear            String?
  cgpa               String?
  description        String?          @db.Text
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([jobSeekerProfileId])
}

model Experience {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  company            String
  role               String
  location           String?
  startMonth         String?
  startYear          String?
  endMonth           String?
  endYear            String?
  current            Boolean          @default(false)
  description        String?          @db.Text
  skillsUsed         String[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([jobSeekerProfileId])
}

model Project {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  name               String
  description        String           @db.Text
  technologies       String[]
  githubLink         String?
  liveLink           String?
  startDate          String?
  endDate            String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([jobSeekerProfileId])
}

model Certification {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  name               String
  organization       String
  issueDate          String?
  credentialUrl      String?
  createdAt          DateTime         @default(now())

  @@index([jobSeekerProfileId])
}

model Language {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  language           String
  proficiency        String
  createdAt          DateTime         @default(now())

  @@index([jobSeekerProfileId])
}

model Achievement {
  id                 String           @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  title              String
  description        String?          @db.Text
  year               String?
  createdAt          DateTime         @default(now())

  @@index([jobSeekerProfileId])
}

model Company {
  id                 String   @id @default(uuid())
  name               String   @unique
  email              String   @unique
  password           String
  industry           String
  size               String
  logoUrl            String?  @db.Text
  registrationNumber String?
  isVerified         Boolean  @default(false)
  verificationBadge  String   @default("none")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  teamMembers       TeamMember[]
  jobPostings       JobPosting[]
  interviewBatches  InterviewBatch[]
  offerTemplates    OfferTemplate[]

  @@index([name])
  @@index([email])
}

model TeamMember {
  id        String   @id @default(uuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roles     Int      @default(8)
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  password  String?
  
  batchInterviews InterviewBatchInterviewer[]
  interviews      InterviewInterviewer[]

  @@unique([companyId, userId])
  @@index([userId])
  @@index([companyId])
}

model InterviewBatchInterviewer {
  id               String         @id @default(uuid())
  interviewBatchId String
  interviewBatch   InterviewBatch @relation(fields: [interviewBatchId], references: [id], onDelete: Cascade)
  teamMemberId     String
  teamMember       TeamMember     @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([interviewBatchId, teamMemberId])
  @@index([teamMemberId])
}

model InterviewInterviewer {
  id           String     @id @default(uuid())
  interviewId  String
  interview    Interview  @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  teamMemberId String
  teamMember   TeamMember @relation(fields: [teamMemberId], references: [id], onDelete: Cascade)

  @@unique([interviewId, teamMemberId])
  @@index([teamMemberId])
}

model JobPosting {
  id                 String           @id @default(uuid())
  companyId          String
  company            Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  title              String
  department         String?
  description        String           @db.Text
  jobType            String
  locationType       String?
  location           String?
  experienceRequired String?
  requiredSkills     Json
  salaryRange        String?
  deadline           DateTime?
  openings           Int              @default(1)
  status             JobPostingStatus @default(active)
  metadata           Json?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  applications     Application[]
  interviewBatches InterviewBatch[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model Application {
  id                 String            @id @default(uuid())
  jobSeekerProfileId String
  jobSeekerProfile   JobSeekerProfile  @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
  jobPostingId       String
  jobPosting         JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  resumeId           String
  resume             Resume            @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  status             ApplicationStatus @default(applied)
  appliedAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  pipelineIndex      Int               @default(0)

  candidateNotes     String?           @db.Text // Private seeker notes
  isWithdrawn        Boolean           @default(false)

  interviews         Interview[]
  offerLetters       OfferLetter[]
  statusHistory      ApplicationHistory[] 

  @@index([jobSeekerProfileId])
  @@index([jobPostingId])
  @@index([status])
}

model ApplicationHistory {
  id            String            @id @default(uuid())
  applicationId String
  application   Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status        ApplicationStatus
  notes         String?           @db.Text
  createdAt     DateTime          @default(now())

  @@index([applicationId])
  @@index([createdAt])
}



model InterviewBatch {
  id                   String          @id @default(uuid())
  companyId            String
  company              Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobPostingId         String?
  jobPosting           JobPosting?     @relation(fields: [jobPostingId], references: [id])
  startTime            DateTime
  slotDuration         Int
  interviewFormat      InterviewFormat
  selectedCandidateIds String[]
  status               String          @default("scheduled")
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  interviewers InterviewBatchInterviewer[]
  interviews   Interview[]

  @@index([companyId])
  @@index([startTime])
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  application     Application     @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  batchId         String?
  batch           InterviewBatch? @relation(fields: [batchId], references: [id], onDelete: Cascade)
  scheduledTime   DateTime
  durationMinutes Int             @default(15)
  format          InterviewFormat @default(video)
  livekitRoomName String          @unique
  joinLink        String
  status          InterviewStatus @default(scheduled)
  recordingPath   String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  interviewers       InterviewInterviewer[]
  feedbacks          InterviewFeedback[]
  rescheduleRequests RescheduleRequest[]

  @@index([applicationId])
  @@index([scheduledTime])
  @@index([status])
}

model RescheduleRequest {
  id                String        @id @default(uuid())
  interviewId       String
  interview         Interview     @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  requestedByUserId String
  requestedByRole   Int?
  proposedTime      DateTime
  candidateNote     String?       @db.Text
  status            RequestStatus @default(pending)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([interviewId])
  @@index([requestedByUserId])
}

model InterviewFeedback {
  id                   String    @id @default(uuid())
  interviewId          String
  interview            Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  interviewerId        String
  interviewer          User      @relation(fields: [interviewerId], references: [id], onDelete: Cascade)
  technicalRating      Int
  communicationRating  Int
  problemSolvingRating Int
  verdict              Verdict
  notes                String?   @db.Text
  createdAt            DateTime  @default(now())

  @@index([interviewId])
  @@index([interviewerId])
}

model OfferLetter {
  id               String            @id @default(uuid())
  applicationId    String
  application      Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  templateId       String?
  template         OfferTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  
  // Offer Details
  position         String
  department       String?
  salary           Decimal
  currency         String            
  startDate        DateTime
  location         String?
  employmentType   String            
  
  content          Json              
  filePath         String?           
  
  status           OfferLetterStatus @default(pending)
  sentAt           DateTime?
  viewedAt         DateTime?         
  respondedAt      DateTime?

  candidateResponse String?         
  negotiationNote   String?         
  
  companySignature  Json?            
  candidateSignature Json?          
  
  emailSentAt      DateTime?
  whatsappSentAt   DateTime?
  emailOpenCount   Int              @default(0)
  
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([applicationId])
  @@index([status])
  @@index([sentAt])
}

model OfferTemplate {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  content     Json     // HTML template with placeholders
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offers      OfferLetter[]

  @@index([companyId])
  @@index([isDefault])
}